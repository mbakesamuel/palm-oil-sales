# --- Local development (usually leave unset) ---
# Expo Go: API host is inferred from the QR code URL (same IP as Metro).
# Set only if auto-detect fails — use the Network URL from `npm run dev`, not localhost.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.43.249:3000

# --- Internal Android APK / EAS Build (required for release builds) ---
# Set in EAS: eas env:create --name EXPO_PUBLIC_API_BASE_URL --value https://your-app.vercel.app --environment preview
EXPO_PUBLIC_API_BASE_URL=https://your-app.vercel.app
