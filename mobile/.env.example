# --- Local development (optional) ---
# Use your PC LAN IP from `npm run dev` → Network line when testing with Expo Go.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000

# --- Internal Android APK / EAS Build (required for release builds) ---
# Set in EAS: eas env:create --name EXPO_PUBLIC_API_BASE_URL --value https://your-app.vercel.app --environment preview
EXPO_PUBLIC_API_BASE_URL=https://your-app.vercel.app
