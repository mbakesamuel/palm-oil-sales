# Copy to .env and fill in values. Do not commit .env.
# See docs/configuration.md for full reference.

# PostgreSQL (required). Prisma CLI falls back to localhost in prisma.config.ts when unset.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Optional second URL for local `next start` / deploy when you keep a separate dev URL above.
# DATABASE_URL_PROD="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth.js: session signing (set a long random string in production)
# Use either name; both are read in auth.config.ts
AUTH_SECRET=
# NEXTAUTH_SECRET=

# Optional defaults used when initializing company settings / seed paths (lib/env.ts)
# DEFAULT_CURRENCY=XAF
# DEFAULT_VAT_RATE=0.1925
# DEFAULT_INVOICE_PREFIX=PO
